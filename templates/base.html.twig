<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}SymHome{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">SymHome</a>

        <div class="d-flex gap-2 align-items-center">
            <a href="{{ path('app_meuble') }}" class="btn btn-outline-light btn-sm">Produits</a>
            <a href="{{ path('app_cart') }}" class="btn btn-outline-light btn-sm">🛒 Panier</a>

            {% if app.user %}
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_admin') }}" class="btn btn-warning btn-sm">Dashboard Admin</a>
                {% endif %}
                <a href="{{ path('app_commande_history') }}" class="btn btn-outline-light btn-sm">Mes commandes</a>
                <span class="text-white btn-sm">{{ app.user.email }}</span>
                <a href="{{ path('app_logout') }}" class="btn btn-danger btn-sm">Déconnexion</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-light btn-sm">Connexion</a>
                <a href="{{ path('app_register') }}" class="btn btn-outline-light btn-sm">Inscription</a>
            {% endif %}
        </div>
    </div>
</nav>

<main>
    {% block body %}{% endblock %}
</main>

<footer class="bg-dark text-white text-center py-3 mt-5">
    <p class="mb-0">© 2026 SymHome - Mobilier et Décoration</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>