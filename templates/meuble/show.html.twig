{% extends 'base.html.twig' %}

{% block title %}{{ meuble.nom }} - SymHome{% endblock %}

{% block body %}

<div class="container my-5">

    <a href="{{ path('app_meuble') }}" class="btn btn-outline-secondary mb-4">
        ← Retour aux produits
    </a>

    <div class="row bg-white shadow-sm rounded p-4">

        <div class="col-md-6">
            {% if meuble.image %}
                <img src="{{ asset('uploads/meubles/' ~ meuble.image) }}" class="img-fluid rounded" alt="{{ meuble.nom }}">
            {% else %}
                <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="height: 350px;">
                    Aucune image
                </div>
            {% endif %}
        </div>

        <div class="col-md-6">
            <h1 class="fw-bold">{{ meuble.nom }}</h1>

            <p class="text-muted">
                Catégorie :
                {% if meuble.categorie %}
                    {{ meuble.categorie.nom }}
                {% else %}
                    Non définie
                {% endif %}
            </p>

            <h3 class="text-success fw-bold">{{ meuble.prix }} DT</h3>

            <p class="mt-4">{{ meuble.description }}</p>

            <p>
                <strong>Stock disponible :</strong>
                {% if meuble.stock > 0 %}
                    <span class="text-success">{{ meuble.stock }}</span>
                {% else %}
                    <span class="text-danger">Rupture de stock</span>
                {% endif %}
            </p>

            <button class="btn btn-dark btn-lg mt-3" disabled>
                Ajouter au panier
            </button>
        </div>

    </div>

</div>

{% endblock %}