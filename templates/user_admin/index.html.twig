{% extends 'base.html.twig' %}

{% block title %}Gestion Utilisateurs - SymHome{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-4">👥 Gestion des Utilisateurs</h1>

    <a href="{{ path('app_admin') }}" class="btn btn-secondary mb-3">← Retour au Dashboard</a>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Email</th>
                <th>Rôles</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
            <tr>
                <td>{{ user.id }}</td>
                <td>{{ user.email }}</td>
                <td>
                    {% for role in user.roles %}
                        <span class="badge bg-primary">{{ role }}</span>
                    {% endfor %}
                </td>
                <td>
                    {% if 'ROLE_ADMIN' not in user.roles %}
                        <a href="{{ path('app_user_admin_delete', {id: user.id}) }}"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Supprimer cet utilisateur ?')">
                            🗑 Supprimer
                        </a>
                    {% else %}
                        <span class="text-muted">Admin protégé</span>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}